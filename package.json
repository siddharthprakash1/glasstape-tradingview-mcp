{
  "name": "glasstape",
  "version": "0.1.0",
  "description": "Typed, self-healing MCP bridge between Claude and TradingView Desktop over the Chrome DevTools Protocol.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "glasstape": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "serve": "tsx src/cli/index.ts serve",
    "start": "node dist/cli/index.js serve",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "tradingview",
    "mcp",
    "claude",
    "chrome-devtools-protocol",
    "cdp",
    "pine-script",
    "trading",
    "model-context-protocol"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chrome-remote-interface": "^0.33.3",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.31.14",
    "@types/node": "^22.10.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
